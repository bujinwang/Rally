# BadmintonGroup MVP - Production Environment Variables
# Copy this file to .env.production and fill in all values
# NEVER commit .env.production to version control!

# ==========================================
# Application
# ==========================================
NODE_ENV=production
PORT=3001

# ==========================================
# Database (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://badminton_user:YOUR_DB_PASSWORD@your-db-host:5432/badminton_prod
POSTGRES_USER=badminton_user
POSTGRES_PASSWORD=YOUR_DB_PASSWORD
POSTGRES_DB=badminton_prod

# ==========================================
# JWT Authentication
# Generate with: openssl rand -base64 32
# ==========================================
JWT_SECRET=YOUR_GENERATED_JWT_SECRET
JWT_REFRESH_SECRET=YOUR_GENERATED_REFRESH_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=https://yourdomain.com

# ==========================================
# Redis (Optional - app works without cache)
# ==========================================
REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ==========================================
# Frontend URL
# ==========================================
FRONTEND_URL=https://yourdomain.com
API_BASE_URL=https://yourdomain.com/api/v1

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# OAuth Providers (Optional)
# ==========================================
# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/v1/oauth/google/callback

# WeChat OAuth - https://open.weixin.qq.com
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=https://yourdomain.com/api/v1/oauth/wechat/callback

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info

# ==========================================
# Security
# ==========================================
BCRYPT_ROUNDS=12

# ==========================================
# Monitoring (Optional)
# ==========================================
# Sentry - https://sentry.io
# SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID

# Grafana Admin
GRAFANA_ADMIN_PASSWORD=YOUR_GRAFANA_PASSWORD

# ==========================================
# Nginx
# ==========================================
NGINX_PORT=80
NGINX_SSL_PORT=443

# ==========================================
# Stripe Payments (Optional)
# ==========================================
# STRIPE_SECRET_KEY=sk_live_YOUR_KEY
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET
