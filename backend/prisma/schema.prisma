  id          String          @id @default(cuid())
  modelId     String
  model       PredictionModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  inputData   Json // Input features for the prediction
  prediction  Json // Predicted output (forecast array, probability, etc.)
  confidence  Float // Confidence score (0-1)
  explanation String? // Model explainability (feature importance)
  timestamp   DateTime        @default(now())

  @@index([modelId])
  @@index([timestamp])
  @@index([confidence])
  @@map("prediction_results")
}
