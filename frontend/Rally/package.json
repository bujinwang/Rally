    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "~12.0.0",
    "detox": "^20.41.1",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
